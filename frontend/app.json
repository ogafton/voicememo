{
  "expo": {
    "name": "To Do List",
    "slug": "todolist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "todolist",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.todolist.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Pentru a adăuga task-uri prin voce",
        "NSMicrophoneUsageDescription": "Pentru a înregistra vocea ta"
      }
    },
    "android": {
      "package": "com.todolist.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Pentru a adăuga task-uri prin voce",
          "speechRecognitionPermission": "Pentru recunoașterea vocală"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
